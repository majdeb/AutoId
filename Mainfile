<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Time Calculator</title>
</head>
<body style="font-family: sans-serif; padding: 20px;">

    <h2>Add 7:30 to a Time</h2>
    
    <label for="startTime">Select Start Time:</label>
    <input type="time" id="startTime" value="12:00">
    
    <button onclick="calculateNewTime()">Calculate</button>

    <h3 id="result"></h3>

    <script>
        function calculateNewTime() {
            // 1. Get the customer's input value
            const inputVal = document.getElementById('startTime').value;
            
            if (!inputVal) {
                alert("Please select a valid time.");
                return;
            }

            // 2. Separate hours and minutes
            let [inputHours, inputMinutes] = inputVal.split(':').map(Number);

            // 3. Add 7 hours and 30 minutes
            let addedHours = 7;
            let addedMinutes = 30;

            let totalMinutes = inputMinutes + addedMinutes;
            let carryHours = Math.floor(totalMinutes / 60);
            
            let finalMinutes = totalMinutes % 60;
            let finalHours = (inputHours + addedHours + carryHours) % 24;

            // 4. Format the result to always show two digits (e.g., 09 instead of 9)
            const formatTime = (h, m) => {
                return `${String(h).padStart(2, '0')}:${String(m).padStart(2, '0')}`;
            };

            // 5. Output the result
            const resultString = `New Time: ${formatTime(finalHours, finalMinutes)}`;
            document.getElementById('result').innerText = resultString;
        }
    </script>
</body>
</html>
